#!/bin/bash
set -euo pipefail
cd {{ app_dir }}

echo "Checking target: {{ app_base_url }}/metrics"
for i in $(seq 1 60); do
  if curl -fsS "{{ app_base_url }}/metrics" >/dev/null; then
    break
  fi
  echo "Target is not ready yet. Retry $i/60..."
  sleep 5
done

curl -fsS "{{ app_base_url }}/metrics" >/dev/null

echo "API metrics: OK"

echo "Balance endpoint:"
curl -fsS "{{ app_base_url }}/api/v1/accounts/1001/balance"
echo

echo "Transaction status endpoint:"
curl -fsS "{{ app_base_url }}/api/v1/transactions/txn0000000000000000000001/status"
echo
